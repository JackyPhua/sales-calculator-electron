{
  "name": "sales-pro",
  "version": "1.0.5",
  "description": "SalesPro — Sales Commission, Reports & Route Planner",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "prebuild:win": "node scripts/copy-route-planner.js",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "sales",
    "commission",
    "calculator",
    "excel",
    "payroll"
  ],
  "author": "SalesPro",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9"
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0"
  },
  "build": {
    "appId": "com.salespro.app",
    "productName": "SalesPro",
    "artifactName": "SalesPro-Setup-${version}.${ext}",
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/*.ts",
      "!**/*.md",
      "!license-generator.js",
      "!dist/**",
      "!landing-page.html",
      "!resources/route-planner/**"
    ],
    "extraResources": [
      {
        "from": "resources/route-planner",
        "to": "route-planner",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SalesPro"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icon.png"
    }
  }
}
