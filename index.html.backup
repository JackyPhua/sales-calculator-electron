<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sales Commission Calculator</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        * {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        body {
            overflow: hidden;
        }
        
        .card {
            transition: all 0.2s ease;
        }
        
        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        }
        
        .btn-primary {
            transition: all 0.2s ease;
        }
        
        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.4);
        }
        
        .btn-primary:active {
            transform: translateY(0);
        }
        
        .sidebar-btn {
            transition: all 0.2s ease;
            position: relative;
        }
        
        .sidebar-btn:hover {
            background-color: #eff6ff;
        }
        
        .sidebar-btn.active {
            background-color: #dbeafe;
            border-left: 4px solid #3b82f6;
        }
        
        .sidebar-btn.active::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 4px;
            background-color: #3b82f6;
        }
        
        .input-field:focus {
            outline: none;
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        }
        
        .achievement-badge {
            animation: pulse 2s infinite;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.7; }
        }
        
        .scrollbar-thin::-webkit-scrollbar {
            width: 8px;
        }
        
        .scrollbar-thin::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 4px;
        }
        
        .scrollbar-thin::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        
        .scrollbar-thin::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
    </style>
</head>
<body class="bg-gray-50">
    
    <!-- Main Container -->
    <div class="flex h-screen">
        
        <!-- Sidebar -->
        <div class="w-64 bg-white border-r border-gray-200 flex flex-col">
            <!-- Logo/Header -->
            <div class="p-6 border-b border-gray-200">
                <div class="flex items-center space-x-2">
                    <div class="w-10 h-10 bg-blue-500 rounded-lg flex items-center justify-center">
                        <span class="text-white text-xl font-bold">💰</span>
                    </div>
                    <div>
                        <h1 class="text-lg font-bold text-gray-900">Sales Calc</h1>
                        <p class="text-xs text-gray-500">v1.0.0</p>
                    </div>
                </div>
            </div>
            
            <!-- Navigation -->
            <nav class="flex-1 p-4 space-y-2">
                <button onclick="switchView('quick')" 
                        class="sidebar-btn active w-full text-left px-4 py-3 rounded-lg flex items-center space-x-3" 
                        data-view="quick">
                    <span class="text-xl">⚡</span>
                    <span class="font-medium text-gray-700">Quick Calculate</span>
                </button>
                
                <button onclick="switchView('salary')" 
                        class="sidebar-btn w-full text-left px-4 py-3 rounded-lg flex items-center space-x-3"
                        data-view="salary">
                    <span class="text-xl">💵</span>
                    <span class="font-medium text-gray-700">Salary & Allowances</span>
                </button>
                
                <button onclick="switchView('commission')" 
                        class="sidebar-btn w-full text-left px-4 py-3 rounded-lg flex items-center space-x-3"
                        data-view="commission">
                    <span class="text-xl">💰</span>
                    <span class="font-medium text-gray-700">Commission Rates</span>
                </button>
                
                <button onclick="switchView('incentive')" 
                        class="sidebar-btn w-full text-left px-4 py-3 rounded-lg flex items-center space-x-3"
                        data-view="incentive">
                    <span class="text-xl">🎁</span>
                    <span class="font-medium text-gray-700">Incentives</span>
                </button>
                
                <div class="h-px bg-gray-200 my-4"></div>
                
                <button onclick="switchView('settings')" 
                        class="sidebar-btn w-full text-left px-4 py-3 rounded-lg flex items-center space-x-3"
                        data-view="settings">
                    <span class="text-xl">⚙️</span>
                    <span class="font-medium text-gray-700">Settings</span>
                </button>
            </nav>
            
            <!-- Footer -->
            <div class="p-4 border-t border-gray-200">
                <p class="text-xs text-gray-500 text-center">
                    Made with ❤️ for Sales Team
                </p>
            </div>
        </div>
        
        <!-- Main Content Area -->
        <div class="flex-1 flex flex-col overflow-hidden">
            
            <!-- Top Bar -->
            <div class="bg-white border-b border-gray-200 px-8 py-4 flex items-center justify-between">
                <div>
                    <h2 id="page-title" class="text-2xl font-bold text-gray-900">Quick Calculate</h2>
                    <p id="page-subtitle" class="text-sm text-gray-500">Calculate commissions for your sales team</p>
                </div>
                <div class="flex items-center space-x-3">
                    <button onclick="exportTemplate()" 
                            class="px-4 py-2 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition flex items-center space-x-2">
                        <span>📄</span>
                        <span class="font-medium">Export Template</span>
                    </button>
                </div>
            </div>
            
            <!-- Content -->
            <div id="content-area" class="flex-1 overflow-y-auto p-8 scrollbar-thin">
                <!-- Content will be loaded here -->
            </div>
            
        </div>
    </div>
    
    <!-- Toast Notification -->
    <div id="toast" class="fixed top-4 right-4 transform translate-x-full transition-transform duration-300">
        <div class="bg-white border border-gray-200 rounded-lg shadow-lg p-4 min-w-[300px]">
            <div class="flex items-start space-x-3">
                <span id="toast-icon" class="text-2xl"></span>
                <div class="flex-1">
                    <p id="toast-message" class="font-medium text-gray-900"></p>
                </div>
            </div>
        </div>
    </div>

    <!-- 调试信息 -->
    <div id="debug-info" class="fixed bottom-0 left-0 bg-black bg-opacity-80 text-white text-xs p-2 z-50">
        <div>App State: <span id="debug-state">Loading...</span></div>
        <div>Config: <span id="debug-config">Not loaded</span></div>
    </div>

    <!-- 脚本引用 - 修复后的正确路径 -->
    <script src="src/app.js"></script>
    <script src="src/views.js"></script>
    <script src="src/calculator.js"></script>
    
    <script>
        // 调试脚本
        document.addEventListener('DOMContentLoaded', () => {
            setTimeout(() => {
                if (window.appState) {
                    document.getElementById('debug-state').textContent = 
                        \View: \, People: \\;
                    document.getElementById('debug-config').textContent = 
                        appState.config ? 'Loaded' : 'Failed';
                }
            }, 1000);
        });
        
        // 全局错误处理
        window.addEventListener('error', function(event) {
            console.error('Global error:', event.error);
        });
    </script>
</body>
</html>
